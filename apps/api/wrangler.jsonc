{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pineapple-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-10",
  "routes": [
    {
      "pattern": "pineapple.tylerevans.co",
      "custom_domain": true,
    },
  ],
  "observability": {
    "enabled": true,
  },
}
