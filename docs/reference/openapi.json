            },
            "required": true,
            "name": "assetId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "The asset's maintenance records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaintenanceRecordListResponse"
